{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "biome check .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "sync:embed": "rm -rf ../internal/webui/dist && mkdir -p ../internal/webui/dist && cp -R dist/. ../internal/webui/dist/",
    "test:e2e": "pnpm build && pnpm sync:embed && playwright test"
  },
